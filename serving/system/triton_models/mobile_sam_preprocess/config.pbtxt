# CPU preprocessing stage for the ensemble.
# Many cheap instances so preprocessing never blocks the GPU instances.
name: "mobile_sam_preprocess"
backend: "python"
max_batch_size: 0

input [
  { name: "INPUT_IMAGE" data_type: TYPE_STRING dims: [1] },
  { name: "BBOX"        data_type: TYPE_FP32   dims: [4] }
]

output [
  { name: "IMAGE_TENSOR" data_type: TYPE_FP32 dims: [1, 3, 1024, 1024] },
  { name: "POINT_COORDS" data_type: TYPE_FP32 dims: [1, 5, 2] },
  { name: "POINT_LABELS" data_type: TYPE_FP32 dims: [1, 5] },
  { name: "ORIG_SIZE"    data_type: TYPE_FP32 dims: [2] }
]

instance_group [{ count: 4, kind: KIND_CPU }]
