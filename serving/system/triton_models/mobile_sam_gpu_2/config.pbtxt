# Stage 4: 2 GPU instances, no dynamic batching
# Shows scaling instances reduces queuing delay under concurrency
name: "mobile_sam_gpu_2"
backend: "python"
max_batch_size: 8

input [
  { name: "INPUT_IMAGE" data_type: TYPE_STRING dims: [1] },
  { name: "BOX"         data_type: TYPE_FP32   dims: [4] }
]

output [
  { name: "MASK"       data_type: TYPE_STRING dims: [1] },
  { name: "ENCODER_MS" data_type: TYPE_FP32   dims: [1] },
  { name: "DECODER_MS" data_type: TYPE_FP32   dims: [1] }
]

instance_group [{ count: 2, kind: KIND_GPU, gpus: [0] }]
